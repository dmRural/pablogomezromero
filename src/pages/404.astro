---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE } from "../consts";
import Title from "../components/Title.astro";
import SectionTitle from "../components/SectionTitle.astro";
import Button from "../components/Button.astro";
import Banner from "../components/Banner.astro";
---

<Layout
  title="Página no encontrada | Pablo Gómez Romero - Asesor Financiero"
  description="Página no encontrada. Descubre los servicios de asesoría financiera para emprendedores y PYME de Pablo Gómez Romero. Volver al inicio."
>
  <main>
    <div class="container mx-auto px-5 py-10">
      <SectionTitle text="404" variant="default" size="xl" />
      <Banner>
        <div class="max-w-3xl mx-auto text-center flex flex-col gap-6">
          <Title variant="light">¡Vaya! Aquí no hay nada... todavía</Title>
          <p class="text-lg md:text-xl leading-relaxed text-sky-100">
            Como buen emprendedor, a veces los proyectos no salen como uno
            espera...<br />
            Esta página es como ese negocio que nunca arrancó, pero al menos nos
            reímos juntos.<br />
            <span class="font-bold text-sky-200"
              >¿Te animas a volver a intentarlo?</span
            >
          </p>
          <a href="/" class="flex justify-center mt-6">
            <Button variant="white" size="lg">Volver a la Home</Button>
          </a>
        </div>
      </Banner>
    </div>
  </main>
</Layout>
