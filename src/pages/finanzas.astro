---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE } from "../consts";
import Title from "../components/Title.astro";
import SectionTitle from "../components/SectionTitle.astro";
import SubSubTitle from "../components/SubSubTitle.astro";
import SubSubSubTitle from "../components/SubSubSubTitle.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
import Banner from "../components/Banner.astro";
import Block from "../components/Block.astro";
import AccentText from "../components/AccentText.astro";
import Bullet from "../components/Bullet.astro";
import WhatsappLink from "../components/WhatsappLink.astro";
import ProgressBlocks from "../components/ProgressBlocks.astro";
import BlockContainer from "../components/BlockContainer.astro";
import SubTitle from "../components/SubTitle.astro";

const metodologia = [
  {
    titulo: "Análisis financiero completo",
    texto:
      "Realizo un estudio detallado de tu situación económica y patrimonial para identificar oportunidades y riesgos.",
  },
  {
    titulo: "Concienciación del largo plazo",
    texto:
      "Te ayudo a entender la importancia de planificar a largo plazo, para que tus decisiones financieras sean sostenibles y seguras.",
  },
  {
    titulo: "Seguimiento periódico",
    texto:
      "Mantengo un contacto regular contigo para revisar y ajustar tu estrategia financiera según cambien tus circunstancias y el entorno.",
  },
];
---

<Layout
  title="Asesor Financiero y Gestión Patrimonial | Pablo Gómez Romero"
  description="Asesoría financiera especializada para particulares y empresas. Te ayudo a proteger tu patrimonio, optimizar inversiones y alcanzar libertad financiera. Contacta ahora."
  keywords="asesoría financiera, consultoría económica, gestión patrimonial, asesor financiero, Pablo Gómez Romero, finanzas personales, finanzas empresariales, planificación financiera"
  structuredDataPage="finanzas"
>
  <main>
    <div class="container mx-auto px-5 py-10">
      <SectionTitle text="FINANZAS" variant="default" size="xl" />

      <div class="mx-auto space-y-8">
        <Block>
          <div class="max-w-4xl mx-auto text-center flex flex-col gap-6">
            <Title>¿Cuáles son MIS SERVICIOS?</Title>
            <Text align="center">
              Muchas veces pensamos que no necesitamos ayuda para gestionar
              nuestro patrimonio, pero igual que acudimos al
              <AccentText>doctor</AccentText> o al
              <AccentText>mecánico</AccentText>, es mejor dejar estos asuntos en
              manos de un experto. Mi objetivo es ayudarte a tomar las mejores
              decisiones financieras para tu tranquilidad y futuro.
            </Text>
          </div>
        </Block>

        <Banner class="flex flex-col items-center">
          <SubSubSubTitle variant="light">
            ¿Listo para mejorar tu salud financiera?
          </SubSubSubTitle>
          <Text align="center">
            Solicita tu sesión de asesoramiento gratuita y descubre cómo puedo
            ayudarte a tomar decisiones inteligentes y alcanzar tu independencia
            financiera.
          </Text>
          <Text align="center">
            Te acompaño en cada etapa, desde el análisis hasta la planificación. <AccentText
              variant="gray">Respondo personalmente a cada consulta.</AccentText
            >
          </Text>
          <div>
            <WhatsappLink
              text="Hola, quiero mejorar mi salud financiera"
              class="mt-6 w-full flex justify-center"
            >
              <Button variant="white" size="lg"
                >Quiero asesoramiento financiero</Button
              >
            </WhatsappLink>
          </div>
        </Banner>

        <div class="text-center mb-8">
          <SubTitle>Áreas de Especialización Financiera</SubTitle>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <BlockContainer
            backgroundImage="/images/pablo-gomez-asesoria-financiera-1.png"
            alt="Análisis financiero Pablo Gómez Romero"
            overlayColor="bg-gray-600/80"
          >
            <SubSubTitle variant="light">Profesionalidad Integral</SubSubTitle>
            <Text>
              Cada caso es único. Realizo <AccentText variant="gray"
                >análisis financieros</AccentText
              > e <AccentText variant="gray">informes personalizados</AccentText
              > para organizar la estructura económica de cada cliente. Asesoro de
              forma independiente a particulares y empresas en:
            </Text>
            <div class="mt-4 space-y-2">
              <Bullet text="Seguros" />
              <Bullet text="Inversiones" />
              <Bullet text="Planes de ahorro y jubilación" />
              <Bullet text="Técnicas de ahorro" />
              <Bullet text="Acortamiento de hipotecas" />
            </div>
          </BlockContainer>

          <BlockContainer
            backgroundImage="/images/pablo-gomez-asesoria-financiera-2.png"
            alt="Servicio cercano Pablo Gómez Romero"
            overlayColor="bg-gray-600/80"
          >
            <SubSubTitle variant="light">Servicio cercano</SubSubTitle>
            <Text>
              Hablo contigo sobre tus deseos y necesidades, diseño soluciones
              personalizadas para proteger tus ingresos e inversiones, y te
              aconsejo para diversificar correctamente tu dinero, equilibrando <AccentText
                variant="gray">seguridad</AccentText
              >, <AccentText variant="gray">rentabilidad</AccentText>, <AccentText
                variant="gray">fiscalidad</AccentText
              >, <AccentText variant="gray">inflación</AccentText> y <AccentText
                variant="gray">liquidez</AccentText
              >.
            </Text>
          </BlockContainer>
        </div>

        <SectionTitle
          text="Invierte para tu futuro"
          description="Descubre el método que te ayudará a tomar decisiones inteligentes y alcanzar la libertad financiera."
          variant="default"
          size="lg"
        />
        <ProgressBlocks steps={metodologia} />
      </div>
    </div>
  </main>
</Layout>
