---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE } from "../consts";
import Title from "../components/Title.astro";
import SectionTitle from "../components/SectionTitle.astro";
import SubSubTitle from "../components/SubSubTitle.astro";
import SubSubSubTitle from "../components/SubSubSubTitle.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
import Banner from "../components/Banner.astro";
import Block from "../components/Block.astro";
import { Vimeo } from "astro-embed";
import AccentText from "../components/AccentText.astro";
---

<Layout
  title={`Formación | ${SITE_TITLE}`}
  description="Cursos y formaciones especializadas en finanzas, economía y educación financiera con Pablo Gómez Romero"
>
  <main>
    <div class="container mx-auto px-5 py-10">
      <SectionTitle text="CURSOS" variant="gradient" size="xl" />

      <div class="mx-auto space-y-8">
        <!-- Sección destacada de introducción -->
        <Banner>
          <div class="max-w-4xl mx-auto text-center flex flex-col gap-6">
            <Title variant="light"> Formación que marca la diferencia </Title>
            <p class="text-lg md:text-xl leading-relaxed text-sky-100">
              Este servicio consiste en diversas
              <AccentText variant="gray">FORMACIONES y CONFERENCIAS</AccentText>
              realizadas en un tono y ambiente distendido, cercano, cordial y sin
              tecnicismos. Los asistentes deben entender perfectamente los contenidos
              y usarlos luego en su vida diaria.
            </p>
            <div class="border-t border-sky-300 pt-6">
              <p class="text-sky-100 text-lg font-medium mb-4">
                ¿Piensas que está todo inventado en el mundo de la Formación?
              </p>
              <p class="text-white text-xl font-semibold">
                Cuenta con nosotros para que sean más dinámicas y especiales…
              </p>
            </div>
          </div>
        </Banner>

        <!-- Eventos donde participamos -->
        <div
          class="bg-white border-l-4 border-sky-500 p-6 rounded-lg shadow-md"
        >
          <h3 class="text-xl font-semibold text-gray-800 mb-4">
            Eventos y Actos formativos en los que participamos:
          </h3>
          <div class="grid md:grid-cols-2 gap-4 text-gray-700">
            <div class="flex items-center space-x-2">
              <span class="w-2 h-2 bg-sky-500 rounded-full"></span>
              <span>Eventos de Empresas</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="w-2 h-2 bg-sky-500 rounded-full"></span>
              <span>Presentaciones de Productos/Servicios</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="w-2 h-2 bg-sky-500 rounded-full"></span>
              <span>Actos de Asociaciones</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="w-2 h-2 bg-sky-500 rounded-full"></span>
              <span>Reuniones Profesionales</span>
            </div>
          </div>
          <p class="mt-4 text-gray-600 font-medium">
            Colaboramos habitualmente con <span
              class="text-sky-600 font-semibold">Centros de Estudios</span
            >,
            <span class="text-sky-600 font-semibold">Escuelas de Negocios</span>
            y
            <span class="text-sky-600 font-semibold">Universidades</span>.
          </p>
        </div>

        <!-- FORMACIÓN PRESENCIAL Y ONLINE -->
        <div class="grid md:grid-cols-2 gap-8">
          <!-- FORMACIÓN PRESENCIAL -->
          <Block variant="gray">
            <SubSubTitle>PRESENCIAL</SubSubTitle>

            <div class="space-y-8 mt-6">
              <div>
                <SubSubSubTitle>
                  Talleres de Educación Financiera básica
                </SubSubSubTitle>
                <Text>
                  Un proceso de educación financiera a un nivel básico está
                  enfocado en los conceptos del dinero y las maneras para
                  manejarlo adecuadamente a partir de generar habilidades en el
                  uso de diversas herramientas financieras. Este proceso se
                  adapta a todo nivel de conocimientos, edades y condiciones
                  sociales.
                </Text>
              </div>

              <div>
                <SubSubSubTitle>
                  Cursos específicos de finanzas
                </SubSubSubTitle>
                <Text>
                  Adaptamos nuestros cursos a cualquier punto referente a la
                  economía como ciencia social que estudia la forma de
                  administrar los recursos disponibles para satisfacer las
                  necesidades humanas. Por supuesto, también evaluamos el
                  comportamiento y las acciones de los seres humanos con
                  referencia a la economía.
                </Text>
              </div>

              <div>
                <SubSubSubTitle> Talleres de Economía </SubSubSubTitle>
                <Text>
                  Adaptamos nuestros cursos a cualquier punto referente a la
                  economía como ciencia social que estudia la forma de
                  administrar los recursos disponibles para satisfacer las
                  necesidades humanas. Por supuesto, también evaluamos el
                  comportamiento y las acciones de los seres humanos con
                  referencia a la economía.
                </Text>
              </div>
              <div
                class="text-center mt-12 p-8 bg-gradient-to-r from-sky-500 to-purple-600 text-white rounded-lg"
              >
                <h3 class="text-2xl font-bold mb-4">
                  ¿Interesado en nuestros cursos?
                </h3>
                <p class="mb-6">
                  Contacta con nosotros para más información sobre nuestros
                  programas de formación
                </p>
                <a
                  href="https://wa.me/34659291511?text=Hola,%20estoy%20interesado%20en%20información%20sobre%20los%20cursos%20de%20formación"
                  target="_blank"
                >
                  <Button variant="white">Contactar con nosotros</Button>
                </a>
              </div>
            </div>
          </Block>

          <!-- FORMACIÓN ONLINE -->
          <Block variant="blue">
            <SubSubTitle>ONLINE</SubSubTitle>

            <div class="space-y-6 mt-6">
              <Text>Descubre nuestros cursos online</Text>
              <Text />
              <div class="mb-6">
                <Vimeo id="502573980" />
              </div>
              <div
                class="text-center mt-12 p-8 bg-gradient-to-r from-orange-600 to-red-500 text-white rounded-lg"
              >
                <h3 class="text-2xl font-bold mb-4">
                  ¿Quieres probar el curso online?
                </h3>
                <p class="mb-6">
                  Puedes acceder a la plataforma y explorarlo tú mismo.
                </p>
                <a href="https://produccionesanafilaxis.com/" target="_blank">
                  <Button variant="white">Acceder a la plataforma</Button>
                </a>
              </div>
            </div>
          </Block>
        </div>
      </div>
    </div>
  </main>
</Layout>
