---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  structuredDataPage?: "home" | "emprendimiento" | "finanzas" | "formacion";
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  keywords,
  structuredDataPage = "home",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={title}
      description={description}
      keywords={keywords}
      structuredDataPage={structuredDataPage}
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
