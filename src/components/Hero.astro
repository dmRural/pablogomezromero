---
export interface Props {
  bg?: string;
}

const { bg = "" } = Astro.props;
---

<section class={`min-h-screen flex items-center ${bg}`}>
  <div
    class="container mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 px-5 py-24 items-center"
  >
    <div
      class="flex flex-col md:items-start md:text-left items-center text-center"
    >
      <slot name="left" />
    </div>
    <div class="flex justify-center items-center">
      <slot name="right" />
    </div>
  </div>
</section>
