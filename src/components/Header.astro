---
import { SITE_TITLE } from "../consts";
---

<header>
  <div class="container mx-auto">
    <div
      class="flex flex-col p-5 md:flex-row md:items-center md:justify-between"
    >
      <div class="flex flex-row items-center justify-between lg:justify-start">
        <a
          href="/"
          class="text-lg font-bold tracking-tighter text-sky-800 transition duration-500 ease-in-out lg:pr-8"
        >
          <img class="h-20 w-auto" src="/logo.png" alt="Pablo Gómez Romero" />
        </a>
        <button
          id="mobile-menu-button"
          class="rounded-lg focus:outline-none md:hidden"
        >
          <svg fill="currentColor" viewBox="0 0 20 20" class="size-8">
            <path
              id="menu-open-icon"
              fill-rule="evenodd"
              d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM9 15a1 1 0 011-1h6a1 1 0 110 2h-6a1 1 0 01-1-1z"
              clip-rule="evenodd"></path>
            <path
              id="menu-close-icon"
              fill-rule="evenodd"
              d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
              clip-rule="evenodd"
              style="display: none"></path>
          </svg>
        </button>
      </div>
      <nav
        id="mobile-menu"
        class="hidden grow flex-col md:flex md:flex-row md:justify-end fixed top-0 left-0 w-full h-full bg-white/95 z-50 shadow-lg transition-all duration-300 ease-in-out md:static md:w-auto md:h-auto md:bg-transparent md:shadow-none"
      >
        <ul
          class="list-none space-y-4 px-6 pt-24 pb-8 lg:inline-flex lg:items-center lg:space-y-0 lg:px-0 lg:pt-0 lg:pb-0"
        >
          <li>
            <a
              href="/formacion"
              class="block rounded-lg border-b-2 border-transparent px-4 py-4 text-base font-semibold text-gray-700 hover:border-sky-600 hover:bg-sky-50 hover:text-sky-600 transition-colors duration-200 md:px-3 md:py-6 lg:px-6 lg:py-6"
            >
              Formación
            </a>
          </li>
          <li>
            <a
              href="/emprendimiento"
              class="block rounded-lg border-b-2 border-transparent px-4 py-4 text-base font-semibold text-gray-700 hover:border-sky-600 hover:bg-sky-50 hover:text-sky-600 transition-colors duration-200 md:px-3 md:py-6 lg:px-6 lg:py-6"
            >
              Emprendimiento
            </a>
          </li>
          <li>
            <a
              href="/finanzas"
              class="block rounded-lg border-b-2 border-transparent px-4 py-4 text-base font-semibold text-gray-700 hover:border-sky-600 hover:bg-sky-50 hover:text-sky-600 transition-colors duration-200 md:px-3 md:py-6 lg:px-6 lg:py-6"
            >
              Finanzas
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuOpenIcon = document.getElementById("menu-open-icon");
    const menuCloseIcon = document.getElementById("menu-close-icon");

    if (mobileMenuButton && mobileMenu && menuOpenIcon && menuCloseIcon) {
      mobileMenuButton.addEventListener("click", function () {
        const isHidden = mobileMenu.classList.contains("hidden");

        if (isHidden) {
          // Mostrar menú
          mobileMenu.classList.remove("hidden");
          mobileMenu.classList.add("flex");
          menuOpenIcon.style.display = "none";
          menuCloseIcon.style.display = "block";
        } else {
          // Ocultar menú
          mobileMenu.classList.add("hidden");
          mobileMenu.classList.remove("flex");
          menuOpenIcon.style.display = "block";
          menuCloseIcon.style.display = "none";
        }
      });
    }
  });
</script>
