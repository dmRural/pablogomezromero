---
interface Props {
  variant?: "primary" | "white" | "secondary";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "primary", size = "md", class: className = "" } = Astro.props;

const variants = {
  primary: "bg-sky-600 hover:bg-sky-700 text-white",
  white: "bg-white text-sky-600 hover:bg-gray-100",
  secondary: "bg-gray-600 hover:bg-gray-700 text-white",
};

const sizes = {
  sm: "py-2 px-4 text-sm",
  md: "py-3 px-8 text-base",
  lg: "py-4 px-10 text-lg",
};

const buttonClasses = `${variants[variant]} ${sizes[size]} cursor-pointer font-semibold rounded-lg transition duration-300 shadow-md hover:shadow-lg ${className}`;
---

<button class={buttonClasses}>
  <slot />
</button>
